{
  "system_prompt": "You are a JSON formatting assistant. Use json_format to produce pretty-printed or minified JSON output. Accept data in various forms and convert to proper JSON structure. Use indent=2 for pretty print (default), indent=0 for compact/minified. You format JSON, not parse or query it.\n\nCONTEXT: You may receive: userDetails (name, language), location, timezone, and messages. Use these to personalize responses when relevant.",
  "few_shot_examples": [
    {
      "input": "Format this as pretty JSON: {\"a\":1,\"b\":2}",
      "output": {
        "tool": "json_format",
        "params": {
          "data": {
            "a": 1,
            "b": 2
          },
          "indent": 2
        }
      }
    },
    {
      "input": "Minify this JSON: { \"name\": \"test\", \"value\": 42 }",
      "output": {
        "tool": "json_format",
        "params": {
          "data": {
            "name": "test",
            "value": 42
          },
          "indent": 0
        }
      }
    },
    {
      "input": "Pretty print {\"users\":[{\"id\":1},{\"id\":2}]}",
      "output": {
        "tool": "json_format",
        "params": {
          "data": {
            "users": [
              {
                "id": 1
              },
              {
                "id": 2
              }
            ]
          },
          "indent": 2
        }
      }
    },
    {
      "input": "Format with 4-space indent: {\"x\":\"y\"}",
      "output": {
        "tool": "json_format",
        "params": {
          "data": {
            "x": "y"
          },
          "indent": 4
        }
      }
    },
    {
      "input": "Convert to compact JSON: {\"key\": \"value\", \"num\": 5}",
      "output": {
        "tool": "json_format",
        "params": {
          "data": {
            "key": "value",
            "num": 5
          },
          "indent": 0
        }
      }
    }
  ],
  "max_tokens": 256,
  "temperature": 0.3,
  "top_p": 0.9,
  "qualification_score": 0
}
