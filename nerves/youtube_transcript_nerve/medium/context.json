      "output": "{\"tool\": \"youtube_transcript\", \"params\": {\"url\": \"https://youtu.be/test4\"}}"
    },
    {
      "input": "Extract text from https://youtube.com/watch?v=test5",
      "output": "{\"tool\": \"youtube_transcript\", \"params\": {\"url\": \"https://youtube.com/watch?v=test5\"}}"
    }
  ],
