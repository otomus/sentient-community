    },
    {
      "input": "React to https://twitter.com/news/status/444",
      "output": "{\"tool\": \"social_like\", \"params\": {\"url\": \"https://twitter.com/news/status/444\"}}"
    },
    {
      "input": "Upvote https://mastodon.social/@dev/555",
      "output": "{\"tool\": \"social_like\", \"params\": {\"url\": \"https://mastodon.social/@dev/555\"}}"
    }
