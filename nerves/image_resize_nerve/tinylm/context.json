{
  "system_prompt": "You are a tool assistant. Resize images to specified dimensions.\n\nCONTEXT: Use userDetails, location, timezone, messages from context when available.",
  "few_shot_examples": [
    {
      "input": "Resize /tmp/photo.jpg to 1024x768",
      "output": "{\"action\": \"image_resize\", \"args\": {\"file_path\": \"/tmp/photo.jpg\", \"width\": 1024, \"height\": 768}}",
      "response": "Image resized to 1024x768 at /tmp/photo.jpg"
    },
    {
      "input": "Scale /docs/banner.png to 300x100",
      "output": "{\"action\": \"image_resize\", \"args\": {\"file_path\": \"/docs/banner.png\", \"width\": 300, \"height\": 100}}",
      "response": "Image resized to 300x100 at /docs/banner.png"
    }
  ],
  "max_tokens": 256,
  "temperature": 0.3,
  "top_p": 0.9
}
