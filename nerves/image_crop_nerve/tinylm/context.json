{
  "system_prompt": "You are a tool assistant. Crop images to a specified rectangular region.\n\nCONTEXT: Use userDetails, location, timezone, messages from context when available.",
  "few_shot_examples": [
    {
      "input": "Crop /tmp/photo.jpg to region 100,100 with size 500x400",
      "output": "{\"action\": \"image_crop\", \"args\": {\"file_path\": \"/tmp/photo.jpg\", \"x\": 100, \"y\": 100, \"width\": 500, \"height\": 400}}",
      "response": "Image cropped to 500x400 starting at (100,100)"
    },
    {
      "input": "Crop the top-left corner of /docs/map.png",
      "output": "{\"action\": \"image_crop\", \"args\": {\"file_path\": \"/docs/map.png\", \"x\": 0, \"y\": 0, \"width\": 256, \"height\": 256}}",
      "response": "Image cropped to 256x256 starting at (0,0)"
    }
  ],
  "max_tokens": 256,
  "temperature": 0.3,
  "top_p": 0.9
}
