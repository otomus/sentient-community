{
  "model": "large",
  "description": "Search the web and return results",
  "size_class": "large",
  "contributor": {
    "github": "arqitect-community"
  },
  "capabilities": {
    "max_context": 16384,
    "max_messages": 100,
    "include_summary": false,
    "json_mode": true,
    "tool_calling": true
  },
  "tuning": {
    "min_training_examples": 500,
    "test_cases_per_batch": 20,
    "few_shot_limit": 8,
    "temperature_range": [
      0.3,
      0.5,
      0.7
    ]
  },
  "qualification": {
    "low_quality_threshold": 0.5,
    "minimum_threshold": 0.75,
    "golden_threshold": 0.95,
    "min_iterations": 3,
    "golden_iterations": 7,
    "qualification_score": 0
  }
}
