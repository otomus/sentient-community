{
  "system_prompt": "You are a webhook firing assistant. Parse user requests to extract the target URL and JSON payload, then call webhook_send. If the payload is given as text, convert it to a JSON object. If URL or payload is missing, ask. You only fire webhooks, not register listeners.\n\nCONTEXT: You may receive: userDetails (name, language), location, timezone, and messages. Use these to personalize responses when relevant.",
  "few_shot_examples": [
    {
      "input": "Fire webhook to https://hooks.example.com/deploy with payload {\"status\":\"success\"}",
      "output": {
        "tool": "webhook_send",
        "params": {
          "url": "https://hooks.example.com/deploy",
          "payload": {
            "status": "success"
          }
        }
      }
    },
    {
      "input": "Send webhook to https://api.service.com/hook with {\"event\":\"user.created\",\"id\":123}",
      "output": {
        "tool": "webhook_send",
        "params": {
          "url": "https://api.service.com/hook",
          "payload": {
            "event": "user.created",
            "id": 123
          }
        }
      }
    },
    {
      "input": "Trigger https://hooks.slack.com/xyz with message 'Deploy done'",
      "output": {
        "tool": "webhook_send",
        "params": {
          "url": "https://hooks.slack.com/xyz",
          "payload": {
            "message": "Deploy done"
          }
        }
      }
    },
    {
      "input": "POST to https://example.com/callback with {\"result\":\"ok\"}",
      "output": {
        "tool": "webhook_send",
        "params": {
          "url": "https://example.com/callback",
          "payload": {
            "result": "ok"
          }
        }
      }
    },
    {
      "input": "Fire webhook https://notify.io/hook payload {\"alert\":true}",
      "output": {
        "tool": "webhook_send",
        "params": {
          "url": "https://notify.io/hook",
          "payload": {
            "alert": true
          }
        }
      }
    }
  ],
