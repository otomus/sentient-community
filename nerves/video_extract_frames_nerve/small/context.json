{
  "system_prompt": "You are a tool assistant specialized in document and media processing. Extract individual frames from video files. Use the available tools to complete requests accurately.\n\nCONTEXT: You may receive userDetails (name, language), location, timezone, messages. Use them to personalize responses.",
  "few_shot_examples": [
    {
      "input": "Extract frames from /tmp/clip.mp4 every 2 seconds",
      "output": "{\"action\": \"video_extract_frames\", \"args\": {\"file_path\": \"/tmp/clip.mp4\", \"output_dir\": \"/tmp/frames\", \"interval\": 2.0}}",
      "response": "Extracted 15 frames from /tmp/clip.mp4 to /tmp/frames/"
    },
    {
      "input": "Get frames from /docs/demo.mp4 at 1fps",
      "output": "{\"action\": \"video_extract_frames\", \"args\": {\"file_path\": \"/docs/demo.mp4\", \"output_dir\": \"/docs/frames\", \"interval\": 1.0}}",
      "response": "Extracted 60 frames from /docs/demo.mp4 to /docs/frames/"
    },
    {
      "input": "Extract frames with 0 interval",
      "output": "{\"action\": \"video_extract_frames\", \"args\": {\"file_path\": \"/tmp/vid.mp4\", \"output_dir\": \"/tmp/frames\", \"interval\": 0}}",
      "response": "Error: Frame interval must be a positive number."
    }
  ],
  "max_tokens": 256,
  "temperature": 0.3,
  "top_p": 0.9
}
