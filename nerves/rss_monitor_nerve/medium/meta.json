{
  "model": "medium",
  "description": "Fetch and summarize RSS feed updates",
  "size_class": "medium",
  "contributor": {
    "github": "arqitect-community"
  },
  "capabilities": {
    "max_context": 8192,
    "max_messages": 20,
    "include_summary": false,
    "json_mode": true,
    "tool_calling": true
  },
  "tuning": {
    "min_training_examples": 200,
    "test_cases_per_batch": 15,
    "few_shot_limit": 5,
    "temperature_range": [
      0.3,
      0.5,
      0.7
    ]
  },
  "qualification": {
    "low_quality_threshold": 0.5,
    "minimum_threshold": 0.7,
    "golden_threshold": 0.9,
    "min_iterations": 3,
    "golden_iterations": 7,
    "qualification_score": 0
  }
}
