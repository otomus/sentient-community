{
  "model": "small",
  "description": "Stash or restore work in progress",
  "size_class": "small",
  "contributor": {
    "github": "arqitect-community"
  },
  "capabilities": {
    "max_context": 4096,
    "max_messages": 5,
    "include_summary": true,
    "json_mode": true,
    "tool_calling": true
  },
  "tuning": {
    "min_training_examples": 100,
    "test_cases_per_batch": 10,
    "few_shot_limit": 3,
    "temperature_range": [
      0.3,
      0.5,
      0.7
    ]
  },
  "qualification": {
    "low_quality_threshold": 0.5,
    "minimum_threshold": 0.65,
    "golden_threshold": 0.85,
    "min_iterations": 3,
    "golden_iterations": 5,
    "qualification_score": 0
  }
}
