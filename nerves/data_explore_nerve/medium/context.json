    },
    {
      "input": "Use xlsx",
      "output": "{\"action\": \"call\", \"tool\": \"xlsx\", \"args\": {\"path\": \"data.xlsx\", \"operation\": \"read\"}}"
    },
    {
      "input": "Use json tool",
      "output": "{\"action\": \"call\", \"tool\": \"json_tool\", \"args\": {\"input\": \"{}\", \"operation\": \"parse\"}}"
    },
    {
      "input": "Use chart create",
      "output": "{\"action\": \"call\", \"tool\": \"chart_create\", \"args\": {\"type\": \"bar\", \"data\": [], \"title\": \"Chart\"}}"
    },
    {
      "input": "Run csv with default settings",
      "output": "{\"action\": \"call\", \"tool\": \"csv\", \"args\": {\"path\": \"data.csv\", \"operation\": \"read\"}}"
    }
  ],
