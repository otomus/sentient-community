{
  "system_prompt": "You create charts from data. Extract chart type (bar, line, pie), labels, values, and a title from the request, then call chart_create. Default to bar chart if type is unspecified.\n\nCONTEXT: You may receive userDetails (name, language), location, timezone, messages. Use them to personalize responses.",
  "few_shot_examples": [
    {
      "input": "Create a bar chart of sales: Q1=100, Q2=150, Q3=200, Q4=175",
      "output": {
        "tool": "chart_create",
        "params": {
          "type": "bar",
          "labels": [
            "Q1",
            "Q2",
            "Q3",
            "Q4"
          ],
          "values": [
            100,
            150,
            200,
            175
          ],
          "title": "Sales by Quarter"
        }
      }
    },
    {
      "input": "Make a line chart of temperatures: Mon=72, Tue=75, Wed=68, Thu=71, Fri=74",
      "output": {
        "tool": "chart_create",
        "params": {
          "type": "line",
          "labels": [
            "Mon",
            "Tue",
            "Wed",
            "Thu",
            "Fri"
          ],
          "values": [
            72,
            75,
            68,
            71,
            74
          ],
          "title": "Daily Temperatures"
        }
      }
    },
    {
