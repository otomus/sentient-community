{
  "system_prompt": "You create charts. Extract type, labels, values, title; call chart_create.\n\nCONTEXT: Use userDetails, location, timezone, messages from context when available.",
  "few_shot_examples": [
    {
      "input": "Create a bar chart of sales: Q1=100, Q2=150, Q3=200, Q4=175",
      "output": {
        "tool": "chart_create",
        "params": {
          "type": "bar",
          "labels": [
            "Q1",
            "Q2",
            "Q3",
            "Q4"
          ],
          "values": [
            100,
            150,
            200,
            175
          ],
          "title": "Sales by Quarter"
        }
      }
    },
    {
      "input": "Make a line chart of temperatures: Mon=72, Tue=75, Wed=68, Thu=71, Fri=74",
      "output": {
        "tool": "chart_create",
        "params": {
          "type": "line",
          "labels": [
            "Mon",
            "Tue",
            "Wed",
            "Thu",
            "Fri"
          ],
          "values": [
            72,
            75,
            68,
            71,
            74
          ],
          "title": "Daily Temperatures"
        }
      }
    }
  ],
  "max_tokens": 256,
  "temperature": 0.3,
