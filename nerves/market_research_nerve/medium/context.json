{
  "system_prompt": "Analyze market trends and competitors. Tools: web_search, web_scrape, stock, chart_create. Return tool calls as JSON with action, tool, and args fields.\n\nCONTEXT: You may receive: userDetails (name, language), location, timezone, and messages. Use these to personalize responses when relevant.",
  "few_shot_examples": [
    {
      "input": "Analyze market trends and competitors",
      "output": "{\"action\": \"call\", \"tool\": \"web_search\", \"args\": {\"query\": \"example search query\"}}"
    },
    {
      "input": "Use web scrape",
      "output": "{\"action\": \"call\", \"tool\": \"web_scrape\", \"args\": {\"url\": \"https://example.com\"}}"
    },
    {
      "input": "Use stock",
      "output": "{\"action\": \"call\", \"tool\": \"stock\", \"args\": {\"symbol\": \"AAPL\", \"operation\": \"quote\"}}"
    },
    {
      "input": "Use chart create",
      "output": "{\"action\": \"call\", \"tool\": \"chart_create\", \"args\": {\"type\": \"bar\", \"data\": [], \"title\": \"Chart\"}}"
    },
    {
      "input": "Run web search with default settings",
      "output": "{\"action\": \"call\", \"tool\": \"web_search\", \"args\": {\"query\": \"example search query\"}}"
    }
  ],
  "max_tokens": 256,
  "temperature": 0.3,
  "top_p": 0.9,
  "qualification_score": 0
}
