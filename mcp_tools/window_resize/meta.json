{
  "name": "window_resize",
  "version": "1.0.0",
  "description": "Resize a window by its title to specified dimensions",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "desktop",
  "tags": [
    "window",
    "resize",
    "desktop",
    "automation"
  ],
  "parameters": [
    {
      "name": "title",
      "type": "string",
      "description": "Title (or partial title) of the window to resize",
      "required": true
    },
    {
      "name": "width",
      "type": "integer",
      "description": "Target width in pixels",
      "required": true
    },
    {
      "name": "height",
      "type": "integer",
      "description": "Target height in pixels",
      "required": true
    }
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "pyautogui"
    ]
  }
}
