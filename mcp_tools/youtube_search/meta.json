{
  "name": "youtube_search",
  "version": "1.0.0",
  "description": "Search YouTube videos by query",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "social",
  "tags": [
    "youtube",
    "search",
    "video",
    "media"
  ],
  "parameters": [
    {
      "name": "query",
      "type": "string",
      "description": "Search query for YouTube videos",
      "required": true
    },
    {
      "name": "api_key",
      "type": "string",
      "description": "API key for the YouTube Data API v3",
      "required": true
    },
    {
      "name": "max_results",
      "type": "int",
      "description": "Maximum number of results to return (default 5)",
      "required": false
    }
  ],
  "requires_api_key": true,
  "dependencies": {
    "python": [
      "requests"
    ]
  }
}
