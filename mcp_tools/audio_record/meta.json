{
  "name": "audio_record",
  "version": "1.0.0",
  "description": "Record audio from the microphone for a specified duration",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "media",
  "tags": [
    "audio",
    "record",
    "microphone",
    "capture",
    "sounddevice"
  ],
  "parameters": [
    {
      "name": "output_path",
      "type": "string",
      "description": "Path where the recorded audio will be saved (WAV format)",
      "required": true
    },
    {
      "name": "duration",
      "type": "number",
      "description": "Recording duration in seconds",
      "required": true
    }
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "numpy",
      "sounddevice"
    ]
  }
}
