{
  "name": "mouse_scroll",
  "version": "1.0.0",
  "description": "Scroll the mouse wheel at an optional position",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "desktop",
  "tags": [
    "mouse",
    "scroll",
    "wheel",
    "automation",
    "desktop"
  ],
  "parameters": [
    {
      "name": "clicks",
      "type": "integer",
      "description": "Number of scroll clicks (positive=up, negative=down)",
      "required": true
    },
    {
      "name": "x",
      "type": "integer",
      "description": "X coordinate to scroll at",
      "required": false
    },
    {
      "name": "y",
      "type": "integer",
      "description": "Y coordinate to scroll at",
      "required": false
    }
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "pyautogui"
    ]
  }
}
