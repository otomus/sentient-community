{
  "name": "image_resize",
  "version": "1.0.0",
  "description": "Resize an image to the specified width and height",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "media",
  "tags": [
    "image",
    "resize",
    "scale",
    "dimensions",
    "pillow"
  ],
  "parameters": [
    {
      "name": "input_path",
      "type": "string",
      "description": "Path to the source image file",
      "required": true
    },
    {
      "name": "output_path",
      "type": "string",
      "description": "Path where the resized image will be saved",
      "required": true
    },
    {
      "name": "width",
      "type": "number",
      "description": "Target width in pixels",
      "required": true
    },
    {
      "name": "height",
      "type": "number",
      "description": "Target height in pixels",
      "required": true
    }
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "Pillow"
    ]
  }
}
