{
  "name": "keyboard_press",
  "version": "1.0.0",
  "description": "Press a key or key combination on the keyboard",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "desktop",
  "tags": [
    "keyboard",
    "press",
    "hotkey",
    "shortcut",
    "automation",
    "desktop"
  ],
  "parameters": [
    {
      "name": "key",
      "type": "string",
      "description": "Key to press (e.g. enter, tab, a, f1)",
      "required": true
    },
    {
      "name": "modifiers",
      "type": "string",
      "description": "Comma-separated modifier keys (e.g. ctrl,shift)",
      "required": false
    }
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "pyautogui"
    ]
  }
}
