  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "iot",
  "tags": [
    "iot",
    "thermostat",
    "temperature",
    "hvac"
  ],
  "parameters": [
    {
      "name": "device_id",
      "type": "string",
