{
  "name": "mouse_click",
  "version": "1.0.0",
  "description": "Click the mouse at specified screen coordinates",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "desktop",
  "tags": [
    "mouse",
    "click",
    "automation",
    "desktop"
  ],
  "parameters": [
    {
      "name": "x",
      "type": "integer",
      "description": "X coordinate on screen",
      "required": true
    },
    {
      "name": "y",
      "type": "integer",
      "description": "Y coordinate on screen",
      "required": true
    },
    {
      "name": "button",
      "type": "string",
      "description": "Mouse button to click (left, right, middle)",
      "required": false
    },
    {
      "name": "clicks",
      "type": "integer",
      "description": "Number of clicks to perform",
      "required": false
    }
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "pyautogui"
    ]
  }
}
