{
  "name": "email_reply",
  "version": "1.0.0",
  "description": "Reply to an email message",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "communication",
  "tags": [
    "email",
    "reply",
    "respond",
    "imap",
    "smtp"
  ],
  "parameters": [
    {
      "name": "id",
      "type": "string",
      "description": "Message ID to reply to",
      "required": true
    },
    {
      "name": "body",
      "type": "string",
      "description": "Reply body text",
      "required": true
    },
    {
      "name": "smtp_host",
      "type": "string",
      "description": "SMTP server hostname",
      "required": true
    },
    {
      "name": "smtp_user",
      "type": "string",
      "description": "SMTP authentication username",
      "required": true
    },
    {
      "name": "smtp_pass",
      "type": "string",
      "description": "SMTP authentication password",
      "required": true
    },
    {
      "name": "imap_host",
      "type": "string",
      "description": "IMAP server hostname",
      "required": true
    }
  ],
  "requires_api_key": true
}
