{
  "name": "keyboard_type",
  "version": "1.0.0",
  "description": "Type a text string using keyboard simulation",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "desktop",
  "tags": [
    "keyboard",
    "type",
    "text",
    "automation",
    "desktop"
  ],
  "parameters": [
    {
      "name": "text",
      "type": "string",
      "description": "Text string to type",
      "required": true
    },
    {
      "name": "interval",
      "type": "number",
      "description": "Seconds between each keystroke",
      "required": false
    }
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "pyautogui"
    ]
  }
}
