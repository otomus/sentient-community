{
  "name": "lock_set",
  "version": "1.0.0",
  "description": "Set the state of a smart lock (lock or unlock)",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "iot",
  "tags": [
    "iot",
    "lock",
    "smart-lock",
    "security"
  ],
  "parameters": [
    {
      "name": "device_id",
      "type": "string",
      "description": "Unique identifier of the smart lock",
      "required": true
    },
    {
      "name": "state",
      "type": "string",
      "description": "Desired lock state: 'lock' or 'unlock'",
      "required": true
    },
    {
      "name": "device_host",
      "type": "string",
      "description": "IoT gateway host URL",
      "required": true
    }
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "requests"
    ]
  }
}
