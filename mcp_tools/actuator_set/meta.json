{
  "name": "actuator_set",
  "version": "1.0.0",
  "description": "Set the value of an IoT actuator",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "iot",
  "tags": [
    "iot",
    "actuator",
    "set",
    "control"
  ],
  "parameters": [
    {
      "name": "actuator_id",
      "type": "string",
      "description": "Unique identifier of the actuator",
      "required": true
    },
    {
      "name": "value",
      "type": "string",
      "description": "Value to set on the actuator",
      "required": true
    },
    {
      "name": "device_host",
      "type": "string",
      "description": "IoT gateway host URL",
      "required": true
    }
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "requests"
    ]
  }
}
