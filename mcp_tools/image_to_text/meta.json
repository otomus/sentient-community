{
  "name": "image_to_text",
  "version": "1.0.0",
  "description": "Extract text from an image using OCR (pytesseract)",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "media",
  "tags": [
    "image",
    "ocr",
    "text",
    "extract",
    "tesseract",
    "recognition"
  ],
  "parameters": [
    {
      "name": "image_path",
      "type": "string",
      "description": "Path to the image file to extract text from",
      "required": true
    },
    {
      "name": "language",
      "type": "string",
      "description": "Tesseract language code (default: eng)",
      "required": false,
      "default": "eng"
    }
  ],
  "requires_api_key": false,
  "dependencies": {
    "python": [
      "Pillow",
      "pytesseract"
    ]
  }
}
