{
  "name": "sms_send",
  "version": "1.0.0",
  "description": "Send an SMS text message",
  "implementations": {
    "python": "tool.py"
  },
  "author": {
    "github": "sentient-community"
  },
  "category": "communication",
  "tags": [
    "sms",
    "text",
    "message",
    "send",
    "phone"
  ],
  "parameters": [
    {
      "name": "to",
      "type": "string",
      "description": "Phone number to send to",
      "required": true
    },
    {
      "name": "body",
      "type": "string",
      "description": "Message text",
      "required": true
    },
    {
      "name": "provider",
      "type": "string",
      "description": "SMS provider name (twilio or vonage)",
      "required": true
    },
    {
      "name": "api_key",
      "type": "string",
      "description": "API key for the SMS provider",
      "required": true
    }
  ],
  "requires_api_key": true
}
