{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Nerve Test Cases",
  "description": "Test cases for nerve qualification and tuning",
  "type": "array",
  "minItems": 4,
  "items": {
    "type": "object",
    "required": ["input", "output", "category"],
    "properties": {
      "input": {
        "type": "string",
        "minLength": 1,
        "description": "User input to test"
      },
      "context": {
        "type": "object",
        "description": "Runtime context: user details, location, conversation history. Empty object {} when context doesn't matter",
        "properties": {
          "userDetails": {
            "type": "object",
            "description": "User profile fields (name, language, preferences)",
            "additionalProperties": { "type": "string" }
          },
          "location": {
            "type": "string",
            "description": "User location (city, country)"
          },
          "timezone": {
            "type": "string",
            "description": "User timezone"
          },
          "messages": {
            "type": "array",
            "description": "Recent conversation history (sliding window)",
            "items": {
              "type": "object",
              "required": ["role", "content"],
              "properties": {
                "role": { "type": "string", "enum": ["user", "assistant", "system"] },
                "content": { "type": "string" }
              }
            }
          }
        },
        "additionalProperties": true
      },
      "output": {
        "type": "string",
        "minLength": 1,
        "description": "Expected response text the nerve should produce"
      },
      "category": {
        "type": "string",
        "enum": ["core", "edge", "boundary", "negative"],
        "description": "core=primary functionality, negative=out-of-scope rejection, edge=boundary case, boundary=empty/extreme input"
      },
      "expected_keywords": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Keywords expected in the response (for core tests)"
      },
      "expect_reject": {
        "type": "boolean",
        "description": "Whether the nerve should reject this input (for negative tests)"
      },
      "expected_tool": {
        "type": "string",
        "description": "Tool expected to be called (for core tests)"
      },
      "description": {
        "type": "string",
        "description": "Human-readable description of what this test validates"
      }
    }
  }
}
