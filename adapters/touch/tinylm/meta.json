{
  "model": "tinylm",
  "description": "Touch sense \u2014 translates natural language to structured JSON for file and shell operations.",
  "size_class": "tinylm",
  "contributor": {
    "github": "otomus"
  },
  "capabilities": {
    "json_mode": true,
    "tool_calling": false,
    "max_context": 2048,
    "max_messages": 5,
    "include_summary": false
  },
  "tuning": {
    "min_training_examples": 200,
    "test_cases_per_batch": 15,
    "few_shot_limit": 5,
    "temperature_range": [
      0.1,
      0.2,
      0.3
    ]
  },
  "qualification": {
    "low_quality_threshold": 0.5,
    "minimum_threshold": 0.7,
    "golden_threshold": 0.9,
    "min_iterations": 3,
    "golden_iterations": 7,
    "qualification_timeout": 600,
    "merge_threshold": 3.0,
    "improvement_threshold": 0.95
  }
}
