{
  "model": "moondream2-text-model-f16",
  "description": "Image analysis and description \u2014 examines photos, screenshots, and visual content.",
  "size_class": "small",
  "contributor": {
    "github": "otomus"
  },
  "capabilities": {
    "json_mode": true,
    "tool_calling": false,
    "max_context": 4096,
    "max_messages": 5,
    "include_summary": true
  },
  "tuning": {
    "min_training_examples": 100,
    "test_cases_per_batch": 10,
    "few_shot_limit": 3,
    "temperature_range": [
      0.1,
      0.2,
      0.3
    ]
  },
  "qualification": {
    "minimum_threshold": 0.65,
    "golden_threshold": 0.95,
    "golden_iterations": 5,
    "min_iterations": 3,
    "current_score": 0.1
  }
}
