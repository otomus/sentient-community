{
  "model": "large",
  "description": "Creative content generation \u2014 writing, humor, summaries, poetry.",
  "size_class": "large",
  "contributor": {
    "github": "otomus"
  },
  "capabilities": {
    "json_mode": true,
    "tool_calling": true,
    "max_context": 16384,
    "max_messages": 100,
    "include_summary": false
  },
  "tuning": {
    "min_training_examples": 500,
    "test_cases_per_batch": 20,
    "few_shot_limit": 8,
    "temperature_range": [
      0.5,
      0.7,
      0.9
    ]
  },
  "qualification": {
    "low_quality_threshold": 0.5,
    "minimum_threshold": 0.75,
    "golden_threshold": 0.95,
    "min_iterations": 3,
    "golden_iterations": 7,
    "qualification_timeout": 600,
    "merge_threshold": 3.0,
    "improvement_threshold": 0.95
  }
}
