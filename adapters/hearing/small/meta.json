{
  "size_class": "small",
  "model": "small",
  "max_context": 4096,
  "max_messages": 10,
  "training_max_length": 1024,
  "description": "Hearing sense \u2014 translates natural language to structured JSON for audio operations.",
  "contributor": {
    "github": "otomus"
  },
  "capabilities": {
    "json_mode": true,
    "tool_calling": false
  },
  "tuning": {
    "min_training_examples": 200,
    "test_cases_per_batch": 15,
    "few_shot_limit": 5,
    "lora_rank": 4,
    "lora_epochs": 3,
    "lora_lr": 0.0001,
    "lora_dropout": 0.05,
    "lora_target_modules": [
      "q_proj",
      "v_proj"
    ],
    "warmup_steps": 50,
    "eval_split": 0.1,
    "scheduler": "cosine",
    "quantization": "4bit",
    "batch_size": 2,
    "gradient_accumulation_steps": 4
  },
  "qualification": {
    "low_quality_threshold": 0.5,
    "minimum_threshold": 0.7,
    "golden_threshold": 0.9,
    "min_iterations": 3,
    "golden_iterations": 7,
    "qualification_timeout": 600,
    "merge_threshold": 3.0,
    "improvement_threshold": 0.95
  }
}
