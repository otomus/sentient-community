{
  "sense": "sight",
  "size_class": "large",
  "version": "0.1.0",
  "model": "large",
  "description": "Sight sense \u2014 translates natural language to structured JSON for vision operations.",
  "contributor": {
    "github": "otomus"
  },
  "max_context": 8192,
  "max_messages": 20,
  "capabilities": {
    "json_mode": true,
    "tool_calling": false
  },
  "tuning": {
    "min_training_examples": 200,
    "test_cases_per_batch": 15,
    "few_shot_limit": 5,
    "temperature_range": [
      0.1,
      0.2,
      0.3
    ]
  },
  "qualification": {
    "low_quality_threshold": 0.5,
    "minimum_threshold": 0.7,
    "golden_threshold": 0.9,
    "min_iterations": 3,
    "golden_iterations": 7,
    "qualification_timeout": 600,
    "merge_threshold": 3.0,
    "improvement_threshold": 0.95
  }
}
