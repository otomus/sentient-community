{
  "version": "1.0",
  "profile": "system",
  "filesystem": {
    "read": [
      "**/*"
    ],
    "write": [
      "/tmp/mcparmor/*"
    ]
  },
  "network": {
    "allow": [
      "*:443"
    ],
    "deny_local": true,
    "deny_metadata": true
  },
  "spawn": false,
  "output": {
    "scan_secrets": true
  }
}
